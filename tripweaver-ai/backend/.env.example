# Required
GROQ_API_KEY=your_groq_api_key_here

# Optional — weather (defaults to free Open-Meteo if not set)
# Weatherstack: https://weatherstack.com/ (free tier: 250 calls/month)
# Set either key name — both are supported
# WEATHER_API_KEY=your_weatherstack_key_here
# WEATHERSTACK_API_KEY=your_weatherstack_key_here

# Optional — hotels + flights (defaults to free OpenStreetMap / static if not set)
# Get free test keys at https://developers.amadeus.com/
# HOTELS_PROVIDER=amadeus
# AMADEUS_API_KEY=your_amadeus_key_here
# AMADEUS_API_SECRET=your_amadeus_secret_here
# AMADEUS_ENV=test   # use 'prod' for live data

# Optional — tourist attractions
# Get free key at https://opentripmap.com/product
# OPENTRIPMAP_API_KEY=your_opentripmap_key_here
